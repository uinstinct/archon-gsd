# Archon's user-extension Dockerfile, carrying the GSD (Engine) runtime.
#
# This is a TEMPLATE shipped by the archon-gsd repo. Deploy it as `Dockerfile.user`
# at your Archon checkout root (Archon's gitignored extension slot, see
# Dockerfile.user.example upstream). It extends Archon's locally-built `archon`
# image and layers on node >= 22 plus a container-global GSD install under the
# appuser home. See docs/adr/0001 (why baked + container-global) and docs/adr/0002
# (why this Dockerfile.user + compose-override mechanism over a standalone image).
#
# It also bakes the bot commit identity (COMMIT_AUTHOR_NAME/EMAIL from .env) and
# turns off Claude Code's co-author trailer — see configure-commit-identity.sh.
#
# Built automatically by `docker compose up` once docker-compose.override.yml is
# in place (it points `app.build.dockerfile` here). The base `archon` image must
# already exist — build it first with `docker compose -f docker-compose.yml build`.
ARG BASE_IMAGE=archon
FROM ${BASE_IMAGE}

# Pin the Engine version (re-confirm against upstream if gsd-core moves; the
# integration was investigated against 1.5.0-rc.2). Override via the build arg in
# docker-compose.override.yml or with --build-arg.
ARG GSD_VERSION=1.5.0-rc.2

USER root
# install-gsd-runtime.sh sits at the Archon checkout root (the build context).
COPY install-gsd-runtime.sh /usr/local/bin/install-gsd-runtime.sh
RUN chmod +x /usr/local/bin/install-gsd-runtime.sh \
    && GSD_VERSION="${GSD_VERSION}" APP_USER=appuser /usr/local/bin/install-gsd-runtime.sh

# Bot commit identity + Claude co-author trailer. Values flow from .env ->
# docker-compose.override.yml build args -> these ARGs. Set COMMIT_AUTHOR_NAME
# alone; configure-commit-identity.sh derives the no-reply email from the GitHub
# users API (COMMIT_AUTHOR_EMAIL is an optional override). Baked into /etc config
# (outside the shadowed appuser home). Both knobs are optional; omit the name to
# keep the ambient identity. See ADR 0001 for the home-volume shadow rule.
ARG COMMIT_AUTHOR_NAME=""
ARG COMMIT_AUTHOR_EMAIL=""
COPY configure-commit-identity.sh /usr/local/bin/configure-commit-identity.sh
RUN chmod +x /usr/local/bin/configure-commit-identity.sh \
    && COMMIT_AUTHOR_NAME="${COMMIT_AUTHOR_NAME}" COMMIT_AUTHOR_EMAIL="${COMMIT_AUTHOR_EMAIL}" \
       /usr/local/bin/configure-commit-identity.sh

# Seed entrypoint: Archon mounts the archon_user_home volume over /home/appuser,
# shadowing the baked GSD install, and Docker's empty-volume seeding does not fire
# reliably here. This wrapper copies the /opt/gsd-home stash into the live volume
# on every boot, then exec's Archon's real docker-entrypoint.sh. See ADR 0001.
COPY gsd-seed-entrypoint.sh /usr/local/bin/gsd-seed-entrypoint.sh
RUN chmod +x /usr/local/bin/gsd-seed-entrypoint.sh
ENTRYPOINT ["gsd-seed-entrypoint.sh"]

# Archon's entrypoint (docker-entrypoint.sh) starts as root and drops to appuser
# via gosu; leave the final USER as root so that contract is unchanged.
